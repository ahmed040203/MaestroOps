pipeline {
    agent { label 'worker' }

    environment {
        DOCKER_USER = "ahmed30103"
        SNS_TOPIC   = "arn:aws:sns:us-east-2:897345560390:maestroops-notifications"
        AWS_REGION  = "us-east-2"
    }

    parameters {
        string(name: 'FRONTEND_DOCKER_TAG', defaultValue: 'latest', description: 'Frontend Docker tag from CI')
        string(name: 'BACKEND_DOCKER_TAG',  defaultValue: 'latest', description: 'Backend Docker tag from CI')
    }

    stages {
        stage("Workspace cleanup") {
            steps {
                cleanWs()
            }
        }

        stage('Git: Code Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/ahmed040203/MaestroOps.git'
            }
        }

        stage('Verify: Docker Image Tags') {
            steps {
                script {
                    echo "FRONTEND_DOCKER_TAG: ${params.FRONTEND_DOCKER_TAG}"
                    echo "BACKEND_DOCKER_TAG: ${params.BACKEND_DOCKER_TAG}"
                }
            }
        }

        stage("Update: Kubernetes manifests") {
            steps {
                dir('Devops-Mega-Project-Jenkins-ArgoCD-EKS/kubernetes') {
                    sh """
                        sed -i 's|image: .*backend.*|image: ${DOCKER_USER}/wanderlust-backend:${params.BACKEND_DOCKER_TAG}|g' backend.yaml
                        sed -i 's|image: .*frontend.*|image: ${DOCKER_USER}/wanderlust-frontend:${params.FRONTEND_DOCKER_TAG}|g' frontend.yaml
                    """
                }
            }
        }

        stage("Git: Commit and push manifests") {
            steps {
                withCredentials([gitUsernamePassword(credentialsId: 'github', gitToolName: 'Default')]) {
                    sh '''
                        git config user.email "ci@maestroops.local"
                        git config user.name "MaestroOps CI"
                        git add .
                        git commit -m "Update K8s manifests with new image tags" || echo "No changes to commit"
                        git push https://github.com/ahmed040203/MaestroOps.git HEAD:main
                    '''
                }
            }
        }
    }

    post {
        success {
            sh """
                aws sns publish \
                  --topic-arn "${SNS_TOPIC}" \
                  --subject "MaestroOps CD - SUCCESS (Build #${BUILD_NUMBER})" \
                  --message "Deployment succeeded. Frontend: ${params.FRONTEND_DOCKER_TAG}, Backend: ${params.BACKEND_DOCKER_TAG}. ArgoCD will sync the new manifests to EKS." \
                  --region ${AWS_REGION}
            """
        }
        failure {
            sh """
                aws sns publish \
                  --topic-arn "${SNS_TOPIC}" \
                  --subject "MaestroOps CD - FAILURE (Build #${BUILD_NUMBER})" \
                  --message "Deployment failed at build #${BUILD_NUMBER}. Check Jenkins console: ${BUILD_URL}" \
                  --region ${AWS_REGION}
            """
        }
    }
}
